SO_RAG_PROVIDER_MODE=openai_compatible
SO_RAG_VECTOR_STORE_PROVIDER=chroma
SO_RAG_CHROMA_PERSIST_PATH=data/indexes/chroma
SO_RAG_CHROMA_COLLECTION_NAME=stack_overflow_qa

SO_RAG_LLM_API_KEY=your_llm_api_key
SO_RAG_LLM_BASE_URL=https://api.openai.com/v1
SO_RAG_LLM_MODEL=gpt-4.1-mini
SO_RAG_REWRITE_MODEL=gpt-4.1-mini
SO_RAG_LLM_TIMEOUT_SECONDS=60

SO_RAG_EMBEDDING_API_KEY=your_embedding_api_key
SO_RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
SO_RAG_EMBEDDING_MODEL=text-embedding-3-small
SO_RAG_EMBEDDING_TIMEOUT_SECONDS=30

SO_RAG_USE_LLM_FOR_REWRITE=true
SO_RAG_ENABLE_DUAL_RETRIEVAL=true

# Redis 缓存配置（cache_backend 设为 redis 时生效）
SO_RAG_CACHE_BACKEND=redis
SO_RAG_REDIS_URL=redis://:your_redis_password@127.0.0.1:6379/0
SO_RAG_REDIS_CACHE_PREFIX=so_rag:answer:

# MySQL 查询日志配置（query_log_backend 设为 mysql 时生效）
SO_RAG_QUERY_LOG_BACKEND=mysql
SO_RAG_MYSQL_URL=mysql+pymysql://root:password@127.0.0.1:3306/stack_overflow_rag


先重建索引
python scripts/rebuild_index.py
启动服务
uvicorn app.main:app --reload
跑评测
pytest

http://127.0.0.1:8000/docs

接口测试：


{
  "query": "Supabase 本地运行 edge function 时，console.log 不输出到终端，代码能正常执行但看不到任何日志，这是什么原因？怎么解决？",
  "top_k": 3,
  "return_context": true
}



{
  "query": "Redis 批量写入后反序列化报错怎么办？",
  "top_k": 3,
  "return_context": true
}

{
  "query": "FastAPI 文件上传校验失败怎么办"
}

{
  "query": "How to fix Redis deserialization error after bulk write?",
  "top_k": 5,
  "return_context": false
}

{
  "query": "FastAPI 文件上传校验失败怎么办",
  "top_k": 3,
  "return_context": true
}

5. 启动服务
uvicorn app.main:app --reload
如果 uvicorn 命令不可用，就用：
py -m uvicorn app.main:app --reload
6. 打开页面
启动后访问：
问答页: http://127.0.0.1:8000/
管理页: http://127.0.0.1:8000/admin-ui
Swagger 文档: http://127.0.0.1:8000/docs
健康检查: http://127.0.0.1:8000/api/v1/health
